# Copy this file to .env and replace every change_me value before deploying.

# Runtime image references
HUSTLEOPS_BACKEND_IMAGE=ghcr.io/hustleops/hustleops-public-backend:0.1.1@sha256:0017e7cd11605d3ee7f6d7986896182f1d20e68f0ae00d3f3e028a0534a7f86d
HUSTLEOPS_FRONTEND_IMAGE=ghcr.io/hustleops/hustleops-public-frontend:0.1.1@sha256:07468204bd0b3f75c069a8f25054727fbd3aa99ad488533f14b89e0fa3a1831f
HUSTLEOPS_BACKEND_MIGRATION_IMAGE=ghcr.io/hustleops/hustleops-public-backend-migrate:0.1.1@sha256:6d319090f6c6867e9dce144d9dd0ce7f582b429e371d03c1ed063c59d093595c

# Runtime hardening defaults
COMPOSE_PROFILES=
HUSTLEOPS_FORCE_STDOUT_LOGGING=true

# HustleOps core runtime
POSTGRES_USER=hustleops
# Required by the postgres container on first init. Use a strong unique password.
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=hustleops
# Required because Redis runs with --requirepass.
# Generate with: openssl rand -base64 32
REDIS_PASSWORD=change_me_redis

# Replace both JWT secrets with unique values at least 32 characters long.
# Generate each with: openssl rand -base64 48
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh

# Must be exactly 64 hex characters (32 random bytes hex-encoded).
# Generate with: openssl rand -hex 32
TWO_FACTOR_ENCRYPTION_KEY=change_me_2fa_key

# One-shot bootstrap creates initial admin only when user table is empty.
# Password must be at least 16 characters and must not contain placeholder text.
# Generate with: printf 'Ho1!%s\n' "$(openssl rand -hex 18)"
BOOTSTRAP_ADMIN_EMAIL=admin@hustleops.local
BOOTSTRAP_ADMIN_PASSWORD=change_me_bootstrap_admin_password

# Set to the exact public frontend origin, including scheme and non-standard port if used.
CORS_ORIGIN=https://example.com

# OpenSearch rejects weak bootstrap passwords.
# Use at least 8 characters with uppercase, number, and special character.
# Generate with: printf 'Ho1!%s\n' "$(openssl rand -hex 18)"
OPENSEARCH_ADMIN_PASSWORD=change_me_opensearch

# n8n runtime
# Internal n8n PostgreSQL password. Keep unique from the main app database password.
# Generate with: openssl rand -base64 24
N8N_POSTGRES_PASSWORD=change_me_n8n_pg
# Internal n8n Redis password. Required because n8n-redis uses --requirepass.
# Generate with: openssl rand -base64 24
N8N_REDIS_PASSWORD=change_me_n8n_redis
# Encrypts stored n8n credentials. Changing this later invalidates existing encrypted credentials.
# Generate with: openssl rand -base64 32
N8N_ENCRYPTION_KEY=change_me_n8n_encryption
# Shared secret between n8n main, worker, and task runners.
# Generate with: openssl rand -hex 32
N8N_RUNNERS_AUTH_TOKEN=change_me_n8n_runner_token

# Release metadata
HUSTLEOPS_RELEASE_TAG=v0.1.1
HUSTLEOPS_RELEASE_TRIGGER=release-v0.1.1-6f3bc0507ca8
